FROM debian:trixie-slim
RUN apt-get update && apt-get upgrade -y && apt-get install -y vim curl wget git python3 python3-pip && apt-get clean && rm -rf /var/lib/apt/lists/*
RUN pip3 install --no-cache-dir flask
RUN mkdir -p /home/agent/tools /home/agent/examples
WORKDIR /opt
COPY app.py /opt/app.py
CMD ["python3", "app.py"]
